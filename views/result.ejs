<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Result – DermaScan</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
</head>
<body>

<div class="layout">

  <%- include('partials/sidebar', { currentPage: 'home', user: user }) %>

  <div class="page-main">

    <!-- Desktop topbar -->
    <header class="topbar">
      <div>
        <div class="topbar-title">Analysis Result</div>
        <div class="topbar-sub">Completed just now</div>
      </div>
      <div style="display:flex; gap:10px; align-items:center;">
        <a href="/history" class="btn btn-ghost" style="font-size:13px; padding:7px 14px;">History</a>
        <a href="/"        class="btn btn-primary" style="font-size:13px; padding:7px 16px;">+ New scan</a>
      </div>
    </header>

    <main class="page-content" style="max-width:1100px;">

      <!-- Mobile-only action strip (below mobile topnav) -->
      <div style="display:flex; gap:8px; margin-bottom:16px;" class="mobile-action-strip">
        <a href="/history" class="btn btn-ghost" style="font-size:13px; padding:7px 12px; flex:1; justify-content:center;">
          History
        </a>
        <a href="/" class="btn btn-primary" style="font-size:13px; padding:7px 12px; flex:1; justify-content:center;">
          + New scan
        </a>
      </div>

      <!-- Top grid: verdict left, image right → stacks on mobile -->
      <div class="result-top-grid" style="display:grid; grid-template-columns:1fr 1.5fr; gap:20px; margin-bottom:20px;">

        <!-- Verdict card -->
        <div class="card" style="padding:24px; display:flex; flex-direction:column; gap:16px;">

          <div>
            <span class="badge <%= result === 'Cancer' ? 'badge-cancer' : 'badge-safe' %>" style="margin-bottom:14px;">
              <svg width="7" height="7" viewBox="0 0 7 7"><circle cx="3.5" cy="3.5" r="3.5" fill="currentColor"/></svg>
              <%= result %>
            </span>
            <h2 style="font-size:24px; font-weight:600; margin-bottom:6px; line-height:1.2;">
              <%= cancerType || 'Benign Lesion' %>
            </h2>
            <p style="font-size:13px; color:var(--text-muted);">
              <%= result === 'Cancer'
                ? 'Malignant characteristics detected in the uploaded image.'
                : 'No signs of malignancy found in the uploaded image.' %>
            </p>
          </div>

          <!-- Confidence -->
          <div>
            <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:8px;">
              <span style="font-size:12px; color:var(--text-muted);">Confidence score</span>
              <span style="font-size:30px; font-weight:600; color:<%= result === 'Cancer' ? 'var(--danger)' : 'var(--primary)' %>;">
                <%= Math.round(confidence) %>%
              </span>
            </div>
            <div class="progress-track">
              <div class="progress-fill <%= result === 'Cancer' ? 'danger' : '' %>"
                   style="width:<%= Math.round(confidence) %>%;"></div>
            </div>
            <p style="font-size:12px; color:var(--text-faint); margin-top:6px;">
              <% if (confidence >= 80) { %>High confidence — model is certain.<% } 
                 else if (confidence >= 60) { %>Moderate confidence — follow-up advised.<% } 
                 else { %>Low confidence — clinical assessment needed.<% } %>
            </p>
          </div>

          <!-- Recommendation -->
          <div style="padding:12px 14px; border-radius:var(--radius-sm);
                      background:<%= result === 'Cancer' ? 'var(--danger-bg)' : 'var(--success-bg)' %>;
                      font-size:13px; line-height:1.5;
                      color:<%= result === 'Cancer' ? 'var(--danger)' : 'var(--success)' %>;">
            <%= result === 'Cancer'
              ? '⚠️ Please consult a dermatologist immediately for professional evaluation.'
              : '✓ No immediate concern. Continue regular skin self-checks every 3 months.' %>
          </div>

        </div>

        <!-- Original image -->
        <div class="card" style="padding:16px; overflow:hidden;">
          <div class="card-header">
            <span class="card-title">Uploaded image</span>
            <span class="badge badge-neutral">Original</span>
          </div>
          <img src="<%= original %>" alt="Uploaded skin image"
               style="width:100%; border-radius:10px; max-height:320px; object-fit:cover;"/>
        </div>

      </div>

      <!-- Stage images — 4-col desktop, 2-col mobile -->
      <div class="card" style="padding:20px;">
        <div class="card-header">
          <span class="card-title">Image processing stages</span>
          <span class="badge badge-neutral">4 stages</span>
        </div>

        <div class="stage-grid-4" style="display:grid; grid-template-columns:repeat(4,1fr); gap:14px;">
          <% const stages = [
            { label:'Original',     img:original,     desc:'Raw uploaded image' },
            { label:'Preprocessed', img:preprocessed, desc:'Resized & normalised' },
            { label:'Mask',         img:mask,         desc:'Segmentation mask' },
            { label:'ROI',          img:roi,          desc:'Region of interest' }
          ] %>
          <% stages.forEach((s, i) => { %>
            <div>
              <div style="position:relative; margin-bottom:6px;">
                <img src="<%= s.img %>" alt="<%= s.label %>" class="stage-img"/>
                <span style="position:absolute; top:6px; left:6px; background:rgba(0,0,0,0.5);
                             color:#fff; font-size:10px; font-weight:500; padding:2px 8px;
                             border-radius:999px;"><%= i+1 %></span>
              </div>
              <div style="font-size:13px; font-weight:500; margin-bottom:2px;"><%= s.label %></div>
              <div style="font-size:11px; color:var(--text-faint);"><%= s.desc %></div>
            </div>
          <% }) %>
        </div>
      </div>

    </main>
  </div>
</div>

<style>
  /* Hide mobile action strip on desktop */
  .mobile-action-strip { display: none; }
  @media (max-width: 900px) {
    .mobile-action-strip { display: flex; }
  }
</style>

</body>
</html>
