<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Create Account – DermaScan</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
</head>
<body>

<div class="auth-page">

  <!-- ── Left decorative panel (desktop only) ── -->
  <div class="auth-panel">

    <div class="auth-panel-logo">
      <div class="logo-mark">
        <svg viewBox="0 0 18 18" fill="none">
          <circle cx="9" cy="9" r="6" stroke="#9FE1CB" stroke-width="1.5"/>
          <circle cx="9" cy="9" r="2.5" fill="#9FE1CB"/>
        </svg>
      </div>
      <div>
        <div class="auth-panel-brand">DermaScan</div>
        <div class="auth-panel-tagline">AI Skin Cancer Detection</div>
      </div>
    </div>

    <div class="auth-panel-headline">
      Start screening<br>smarter with <span>AI</span>
    </div>

    <div class="auth-panel-features">
      <div class="auth-feature">
        <div class="auth-feature-icon">📋</div>
        <div class="auth-feature-text">
          <strong>Persistent scan history</strong>
          Every result saved and linked to your account
        </div>
      </div>
      <div class="auth-feature">
        <div class="auth-feature-icon">🧬</div>
        <div class="auth-feature-text">
          <strong>Multi-class detection</strong>
          Melanoma, Nevi, Basal Cell Carcinoma and more
        </div>
      </div>
      <div class="auth-feature">
        <div class="auth-feature-icon">📥</div>
        <div class="auth-feature-text">
          <strong>Downloadable reports</strong>
          PDF reports for every scan to share with your doctor
        </div>
      </div>
    </div>

  </div>

  <!-- ── Right form panel ── -->
  <div class="auth-form-panel">
    <div class="auth-card">

      <!-- Logo (mobile only) -->
      <div class="auth-logo-mobile">
        <div class="logo-mark" style="width:38px; height:38px; border-radius:11px;">
          <svg viewBox="0 0 18 18" fill="none">
            <circle cx="9" cy="9" r="6" stroke="#9FE1CB" stroke-width="1.5"/>
            <circle cx="9" cy="9" r="2.5" fill="#9FE1CB"/>
          </svg>
        </div>
        <div>
          <div style="font-size:20px; font-weight:600; color:var(--text);">DermaScan</div>
          <div style="font-size:12px; color:var(--text-faint);">AI Skin Cancer Detection</div>
        </div>
      </div>

      <h1 class="auth-heading">Create your account</h1>
      <p class="auth-subheading">Free to use. No credit card required.</p>

      <!-- Error message -->
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="auth-error">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" style="flex-shrink:0;">
            <circle cx="8" cy="8" r="6"/><path d="M8 5v3M8 11v.5"/>
          </svg>
          <%= error %>
        </div>
      <% } %>

      <form action="/signup" method="POST" id="signup-form" novalidate>

        <div class="auth-field">
          <label for="username">Username</label>
          <input class="auth-input" type="text" id="username" name="username"
                 required autocomplete="username"
                 placeholder="e.g. rahulk"
                 minlength="3"/>
        </div>

        <div class="auth-field">
          <label for="email">Email address</label>
          <input class="auth-input" type="email" id="email" name="email"
                 required autocomplete="email" inputmode="email"
                 placeholder="you@example.com"/>
        </div>

        <div class="auth-field">
          <label for="password">Password</label>
          <div class="auth-input-wrap">
            <input class="auth-input" type="password" id="password" name="password"
                   required autocomplete="new-password"
                   placeholder="Min. 6 characters"
                   minlength="6"
                   oninput="checkStrength(this.value)"/>
            <button type="button" class="auth-eye" onclick="togglePwd('password', this)" aria-label="Show password">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M1 10s3-6 9-6 9 6 9 6-3 6-9 6-9-6-9-6z"/>
                <circle cx="10" cy="10" r="2.5"/>
              </svg>
            </button>
          </div>
          <!-- Password strength bar -->
          <div id="strength-wrap" style="margin-top:8px; display:none;">
            <div style="display:flex; gap:4px; margin-bottom:4px;">
              <div class="str-seg" id="str-1" style="flex:1; height:3px; border-radius:2px; background:var(--border);"></div>
              <div class="str-seg" id="str-2" style="flex:1; height:3px; border-radius:2px; background:var(--border);"></div>
              <div class="str-seg" id="str-3" style="flex:1; height:3px; border-radius:2px; background:var(--border);"></div>
              <div class="str-seg" id="str-4" style="flex:1; height:3px; border-radius:2px; background:var(--border);"></div>
            </div>
            <div id="strength-label" style="font-size:11px; color:var(--text-faint);"></div>
          </div>
        </div>

        <div class="auth-field" style="margin-bottom:24px;">
          <label for="confirm">Confirm password</label>
          <div class="auth-input-wrap">
            <input class="auth-input" type="password" id="confirm" name="confirm"
                   required autocomplete="new-password"
                   placeholder="Re-enter password"/>
            <button type="button" class="auth-eye" onclick="togglePwd('confirm', this)" aria-label="Show password">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M1 10s3-6 9-6 9 6 9 6-3 6-9 6-9-6-9-6z"/>
                <circle cx="10" cy="10" r="2.5"/>
              </svg>
            </button>
          </div>
          <div id="match-msg" style="font-size:12px; margin-top:6px;"></div>
        </div>

        <button type="submit" class="btn btn-primary" style="width:100%; padding:14px; font-size:15px; justify-content:center;" id="signup-btn">
          Create account
        </button>

      </form>

      <div class="auth-footer">
        Already have an account?
        <a href="/login">Sign in here</a>
      </div>

      <div class="auth-disclaimer">
        ⚠️ For screening only — not a substitute for professional medical advice.
      </div>

    </div>
  </div>

</div>

<script>
  /* ── Show/hide password ── */
  function togglePwd(fieldId, btn) {
    const input = document.getElementById(fieldId);
    const isText = input.type === 'text';
    input.type = isText ? 'password' : 'text';
    btn.querySelector('svg').innerHTML = isText
      ? '<path d="M1 10s3-6 9-6 9 6 9 6-3 6-9 6-9-6-9-6z"/><circle cx="10" cy="10" r="2.5"/>'
      : '<path d="M2 2l16 16M6.5 6.6A7 7 0 0010 4c6 0 9 6 9 6a16.5 16.5 0 01-2.67 3.4M10 16c-6 0-9-6-9-6a16.6 16.6 0 012.32-3.09"/>';
  }

  /* ── Password strength ── */
  function checkStrength(val) {
    const wrap  = document.getElementById('strength-wrap');
    const label = document.getElementById('strength-label');
    const segs  = [1,2,3,4].map(i => document.getElementById('str-'+i));

    if (!val) { wrap.style.display = 'none'; return; }
    wrap.style.display = 'block';

    let score = 0;
    if (val.length >= 6)  score++;
    if (val.length >= 10) score++;
    if (/[A-Z]/.test(val) && /[a-z]/.test(val)) score++;
    if (/[0-9]/.test(val) || /[^A-Za-z0-9]/.test(val)) score++;

    const colors = ['', '#DC2626','#D97706','#059669','#0F6E56'];
    const labels = ['', 'Weak','Fair','Good','Strong'];
    segs.forEach((s, i) => { s.style.background = i < score ? colors[score] : 'var(--border)'; });
    label.textContent = labels[score] || '';
    label.style.color = colors[score] || 'var(--text-faint)';
  }

  /* ── Password match check ── */
  document.getElementById('confirm').addEventListener('input', function() {
    const msg = document.getElementById('match-msg');
    const pw  = document.getElementById('password').value;
    if (!this.value) { msg.textContent = ''; return; }
    if (this.value === pw) {
      msg.textContent = '✓ Passwords match';
      msg.style.color = 'var(--success)';
    } else {
      msg.textContent = '✗ Passwords do not match';
      msg.style.color = 'var(--danger)';
    }
  });

  /* ── Client-side validation before submit ── */
  document.getElementById('signup-form').addEventListener('submit', function(e) {
    const pw  = document.getElementById('password').value;
    const cf  = document.getElementById('confirm').value;
    if (pw !== cf) {
      e.preventDefault();
      document.getElementById('match-msg').textContent = '✗ Passwords do not match';
      document.getElementById('match-msg').style.color = 'var(--danger)';
      document.getElementById('confirm').focus();
      return;
    }
    const btn = document.getElementById('signup-btn');
    btn.disabled = true;
    btn.textContent = 'Creating account…';
  });

  document.getElementById('username').focus();
</script>

</body>
</html>
